<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running
         application to allow hot reload/restart, and to save the observatory
         port used to connect for debugging/profiling. This permission is
         only added for debug builds and is stripped from release builds. -->
    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
